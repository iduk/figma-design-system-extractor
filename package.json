{
  "name": "figma-design-system-extractor",
  "version": "1.0.0",
  "description": "Figma Dev Mode URL → Design System.md 자동 생성",
  "main": "scripts/generate-md.js",
  "scripts": {
    "extract": "bash scripts/extract-figma.sh",
    "parse": "node scripts/parse-tokens.js",
    "map": "node scripts/map-to-code.js",
